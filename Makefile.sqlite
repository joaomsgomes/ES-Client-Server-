# Makefile para ES Server com SQLite
# Use: make -f Makefile.sqlite

CC = gcc
CFLAGS = -Wall -Wextra -pthread -I./include -g
LDFLAGS = -pthread -lsqlite3

# Diretórios
SRC_DIR = src
BUILD_DIR = build
INCLUDE_DIR = include

# Ficheiros fonte - USA user_database.c em vez de user_management.c
SERVER_SRCS = $(SRC_DIR)/server/ES.c \
              $(SRC_DIR)/server/user_database.c \
              $(SRC_DIR)/server/udp_handlers.c \
              $(SRC_DIR)/common/protocol.c \
              $(SRC_DIR)/common/utils.c \
              $(SRC_DIR)/common/file_transfer.c

CLIENT_SRCS = $(SRC_DIR)/client/user.c \
              $(SRC_DIR)/common/protocol.c \
              $(SRC_DIR)/common/utils.c

# Ficheiros objeto
SERVER_OBJS = $(SERVER_SRCS:$(SRC_DIR)/%.c=$(BUILD_DIR)/%.o)
CLIENT_OBJS = $(CLIENT_SRCS:$(SRC_DIR)/%.c=$(BUILD_DIR)/%.o)

# Executáveis
SERVER = ES
CLIENT = user

.PHONY: all clean dirs

all: dirs $(SERVER) $(CLIENT)

dirs:
	@mkdir -p $(BUILD_DIR)/server
	@mkdir -p $(BUILD_DIR)/client
	@mkdir -p $(BUILD_DIR)/common

$(SERVER): $(SERVER_OBJS)
	$(CC) -o $@ $^ $(LDFLAGS)
	@echo "✓ ES Server compiled with SQLite support"

$(CLIENT): $(CLIENT_OBJS)
	$(CC) -o $@ $^ $(LDFLAGS)

$(BUILD_DIR)/%.o: $(SRC_DIR)/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -rf $(BUILD_DIR) $(SERVER) $(CLIENT)
	@echo "Clean complete"

cleandb:
	rm -f es_server.db
	@echo "Database removed"

run_server: $(SERVER)
	./$(SERVER)

run_client: $(CLIENT)
	./$(CLIENT) -n 127.0.0.1 -p 58000

# Migrar dados de USERS/ para SQLite
migrate:
	@echo "Migrating users from USERS/ to SQLite..."
	@if [ -d "USERS" ]; then \
		sqlite3 es_server.db "CREATE TABLE IF NOT EXISTS users (uid TEXT PRIMARY KEY, password TEXT, created_at DATETIME DEFAULT CURRENT_TIMESTAMP);"; \
		for file in USERS/*_pass.txt; do \
			if [ -f "$$file" ]; then \
				uid=$$(basename $$file _pass.txt); \
				password=$$(cat $$file | tr -d '\n'); \
				sqlite3 es_server.db "INSERT OR IGNORE INTO users (uid, password) VALUES ('$$uid', '$$password');"; \
				echo "  Migrated user: $$uid"; \
			fi \
		done; \
		echo "Migration complete!"; \
	else \
		echo "No USERS/ directory found. Nothing to migrate."; \
	fi

# Ver utilizadores na base de dados
listusers:
	@echo "Users in database:"
	@sqlite3 es_server.db "SELECT uid, password, created_at FROM users;" || echo "No database found"

.PHONY: migrate listusers cleandb
